{
  "client": "omniwa-tui",
  "contractVersion": "0.1.0",
  "apiVersion": "v1",
  "statusEnum": [
    "implemented_public",
    "route_exists_not_implemented",
    "internal_only",
    "missing",
    "deprecated",
    "unknown"
  ],
  "sourceOfTruth": {
    "openapi": "docs/api/openapi/omniwa-v1.openapi.json",
    "httpServer": "apps/api/src/http-server.ts",
    "applicationDispatcher": "packages/application/src/services/application-dispatcher.ts",
    "publicDtoMapper": "apps/api/src/public-resource-dto.ts"
  },
  "runtime": {
    "defaultLocalBaseUrl": "http://127.0.0.1:3000",
    "basePath": "/v1",
    "auth": {
      "type": "apiKey",
      "header": "x-api-key"
    },
    "requestHeaders": {
      "requestId": "x-request-id",
      "correlationId": "x-correlation-id",
      "traceId": "x-trace-id",
      "idempotencyKey": "idempotency-key",
      "sseLastEventId": "Last-Event-ID"
    },
    "responseHeaders": ["x-request-id", "x-correlation-id"],
    "successEnvelope": {
      "data": "object|array",
      "meta": {
        "requestId": "string",
        "correlationId": "string",
        "timestamp": "date-time"
      }
    },
    "collectionEnvelope": {
      "data": "array",
      "meta": {
        "requestId": "string",
        "correlationId": "string",
        "timestamp": "date-time",
        "query": "object",
        "pagination": "object"
      }
    },
    "errorEnvelope": {
      "error": {
        "code": "string",
        "message": "string",
        "details": "object"
      },
      "meta": {
        "requestId": "string",
        "correlationId": "string",
        "timestamp": "date-time"
      }
    },
    "pagination": {
      "cursorParam": "cursor",
      "limitParam": "limit",
      "defaultLimit": 50,
      "maxLimit": 200,
      "cursorOpaque": true
    },
    "filtering": {
      "searchParam": "search",
      "sortParam": "sort",
      "unsupportedFilterError": "unsupported_filter",
      "unsupportedSortError": "unsupported_sort"
    }
  },
  "tuiGuidance": {
    "mustUsePublicRestOrSseOnly": true,
    "mustNotCallInternalCommandOrQueryHandlers": true,
    "mustTreatRouteExistsNotImplementedAsDisabledAction": true,
    "mustPreserveRequestAndCorrelationIds": true,
    "recommendedInitialScreens": [
      "health",
      "instances",
      "sessions",
      "events",
      "eventsStream",
      "queue"
    ],
    "disabledUntilBackendHandlersExist": ["audit", "settings", "metrics"]
  },
  "resources": {
    "health": {
      "status": "implemented_public",
      "recommendedForTui": true,
      "dto": "HealthDto",
      "notes": "Usable for backend connectivity and health state."
    },
    "instances": {
      "status": "implemented_public",
      "recommendedForTui": true,
      "dto": "InstanceDto|OperationData",
      "notes": "List, create, detail, and destroy routes are public. Destroy returns an accepted operation envelope, tombstones the instance, hides it from ListInstances, cleans up related local sessions/jobs, and disconnects provider runtime sessions when the provider command bridge is configured."
    },
    "sessions": {
      "status": "implemented_public",
      "recommendedForTui": true,
      "dto": "SessionDto",
      "notes": "Instance-scoped session list is public at /v1/instances/{instanceId}/sessions. Top-level /v1/sessions remains missing."
    },
    "chats": {
      "status": "implemented_public",
      "recommendedForTui": true,
      "dto": "ChatSummaryDto|ChatDetailDto",
      "notes": "Instance-scoped list and detail read routes are public. Global /v1/chats remains disabled for public clients. Public DTOs do not expose raw JIDs, phone numbers, participant identifiers, or provider payloads."
    },
    "contacts": {
      "status": "implemented_public",
      "recommendedForTui": true,
      "dto": "ContactDto",
      "notes": "Instance-scoped list and detail read routes are public. Global /v1/contacts remains disabled for public clients. Public DTOs do not expose raw JIDs, phone numbers, or provider payloads."
    },
    "labels": {
      "status": "route_exists_not_implemented",
      "recommendedForTui": false,
      "dto": "LabelDto",
      "notes": "Routes exist but Application handler is unavailable."
    },
    "messages": {
      "status": "implemented_public",
      "recommendedForTui": true,
      "dto": "MessageDto|OperationData",
      "notes": "Read routes are public for instance-scoped message lists and message status. Text send, retry, and cancel mutations are public and require idempotency-key. Public DTOs do not expose raw text, JID, provider payloads, outbound intent refs, guardrail refs, or domain events."
    },
    "media": {
      "status": "route_exists_not_implemented",
      "recommendedForTui": false,
      "dto": "MediaDto|OperationData",
      "notes": "Register and status routes exist, but Application handlers are unavailable."
    },
    "groups": {
      "status": "implemented_public",
      "recommendedForTui": true,
      "dto": "GroupSummaryDto|GroupDetailDto|GroupMemberDto|OperationData",
      "notes": "Instance-scoped list, group detail, group member read routes, metadata/local-state updates, and controlled member admin mutations are public. Top-level /v1/groups remains missing. Member admin actions require groups:admin and must use safe memberRef values from the members list."
    },
    "queue": {
      "status": "implemented_public",
      "recommendedForTui": true,
      "dto": "MetricsResource",
      "notes": "Queue summary route is public through monitoring/admin credentials. Queue item/action routes are missing."
    },
    "jobs": {
      "status": "implemented_public",
      "recommendedForTui": true,
      "dto": "JobDto",
      "notes": "Read routes are public and require jobs:read, monitoring, or admin credentials."
    },
    "webhooks": {
      "status": "implemented_public",
      "recommendedForTui": true,
      "dto": "WebhookDto|WebhookDeliveryDto|OperationData",
      "notes": "Subscription and delivery read routes plus controlled delivery retry are public. Public DTO does not expose targetUrl, retryPolicy, or domainEvents."
    },
    "events": {
      "status": "implemented_public",
      "recommendedForTui": true,
      "dto": "EventDto",
      "notes": "Event list is public and backed by EventLog replay. Payload is not exposed in public DTOs."
    },
    "eventsStream": {
      "status": "implemented_public",
      "recommendedForTui": true,
      "dto": "RealtimeEventEnvelope",
      "notes": "SSE transport is public and usable. Current local runtime may only emit heartbeat when event log is empty."
    },
    "logs": {
      "status": "missing",
      "recommendedForTui": false,
      "dto": "LogLineDto",
      "notes": "No public logs route."
    },
    "audit": {
      "status": "route_exists_not_implemented",
      "recommendedForTui": false,
      "dto": "AuditEntryDto",
      "notes": "Route exists under /v1/audit-records, requires admin/audit scope, handler unavailable."
    },
    "apiKeys": {
      "status": "implemented_public",
      "recommendedForTui": false,
      "dto": "ApiKeyDto|ApiKeyLifecycleOperationData",
      "notes": "Admin-only API key lifecycle routes are public for platform operators. They require admin:* and never return plaintext keys or keyHash values."
    },
    "settings": {
      "status": "route_exists_not_implemented",
      "recommendedForTui": false,
      "dto": "SettingsDto|OperationData",
      "notes": "Routes exist under /v1/settings, require admin/config scope, handlers unavailable."
    },
    "metrics": {
      "status": "route_exists_not_implemented",
      "recommendedForTui": false,
      "dto": "MetricsResource|DashboardResource",
      "notes": "Routes exist but Application handlers are unavailable and require monitoring/admin scopes."
    }
  },
  "endpoints": [
