.codegraph/

# Database
.codegraph/*.db
.codegraph/*.db-wal
.codegraph/*.db-shm

# Cache
.codegraph/cache/

# Logs
.codegraph/*.log

# Hook markers
.codegraph/.dirty
.codegraph/.gitignore

# Node / package manager
node_modules/
.pnpm-store/

# Build outputs
dist/
coverage/
.turbo/
*.tsbuildinfo
target/
**/target/

# Environment
.env
.env.*
!.env.example
deploy/docker/env/*.env
.omniwa-local/

