{
  "name": "omniwa",
  "version": "0.0.0",
  "private": true,
  "description": "OmniWA implementation workspace.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "arch:check": "node tooling/architecture/check-boundaries.mjs",
    "build": "tsc -b tsconfig.references.json",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm arch:check && pnpm release:check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint \"{apps,packages,tooling}/**/*.{ts,mjs}\"",
    "release:check": "node tooling/release/check-readiness.mjs",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -b tsconfig.references.json --pretty false"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "eslint": "^10.6.0",
    "prettier": "^3.9.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  }
}
