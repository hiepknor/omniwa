{
  "name": "@omniwa/app-provider-runtime",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@omniwa/application": "workspace:*",
    "@omniwa/config": "workspace:*",
    "@omniwa/domain": "workspace:*",
    "@omniwa/errors": "workspace:*",
    "@omniwa/infrastructure-persistence": "workspace:*",
    "@omniwa/infrastructure-provider-baileys": "workspace:*",
    "@omniwa/observability": "workspace:*",
    "@omniwa/shared": "workspace:*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:local-live": "OMNIWA_PROVIDER_RUNTIME_PROFILE=local OMNIWA_LIVE_DEMO_MODE=1 OMNIWA_LOCAL_QR_OUTPUT=file node dist/index.js",
    "test": "vitest run --passWithNoTests"
  }
}
