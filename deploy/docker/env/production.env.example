# Production Docker environment template.
# Do not commit a real production env file.

OMNIWA_IMAGE=ghcr.io/your-org/omniwa:replace-with-version
OMNIWA_API_PUBLIC_PORT=3000

# Current code rejects production profile until P0 production adapters are complete.
# Use "local" only for a controlled pilot that does not claim production readiness.
OMNIWA_API_RUNTIME_PROFILE=local

OMNIWA_API_KEY=replace-with-secret-from-secret-manager
OMNIWA_API_KEY_ID=prod-primary-key
OMNIWA_API_KEY_KIND=admin_key
OMNIWA_API_KEY_SCOPES=admin:*
