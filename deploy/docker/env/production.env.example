# Production Docker environment template.
# Do not commit a real production env file.

OMNIWA_IMAGE=ghcr.io/your-org/omniwa:replace-with-version
OMNIWA_API_PUBLIC_PORT=3000

# API production profile is fail-closed and requires PostgreSQL, Redis rate limiting,
# repository-backed ownership, audit-record evidence, durable queue, PostgreSQL EventLog,
# and metric sinks.
OMNIWA_API_RUNTIME_PROFILE=production
OMNIWA_API_REPOSITORY_PROFILE=postgresql
OMNIWA_EVENT_LOG_BACKEND=postgresql
OMNIWA_POSTGRES_DATABASE=omniwa
OMNIWA_POSTGRES_USER=omniwa_app_prod
OMNIWA_POSTGRES_PASSWORD=replace-with-postgres-secret
OMNIWA_POSTGRES_DATABASE_URL=postgresql://omniwa_app_prod:replace-with-postgres-secret@postgres:5432/omniwa
OMNIWA_POSTGRES_AUTO_MIGRATE=false

OMNIWA_API_KEY_HASH=sha256:replace-with-api-key-sha256-hex
OMNIWA_API_HEALTHCHECK_KEY=replace-with-healthcheck-api-key-matching-hash
OMNIWA_API_KEY_ID=prod-primary-key
OMNIWA_API_KEY_KIND=admin_key
OMNIWA_API_KEY_SCOPES=admin:*

OMNIWA_REDIS_PASSWORD=replace-with-redis-secret
OMNIWA_API_RATE_LIMIT_BACKEND=redis
OMNIWA_API_RATE_LIMIT_REDIS_URL=redis://:replace-with-redis-secret@redis:6379/0
OMNIWA_API_RATE_LIMIT_MAX_REQUESTS=600
OMNIWA_API_RATE_LIMIT_WINDOW_MS=60000

# Worker production profile requires PostgreSQL repositories, durable WorkerJob queue, a durable
# EventLog path, and the provider-runtime bridge. Provider Runtime remains controlled-pilot until
# its production profile is enabled and target-environment bridge evidence is collected.
OMNIWA_WORKER_RUNTIME_PROFILE=production
OMNIWA_WORKER_REPOSITORY_PROFILE=postgresql
OMNIWA_WORKER_QUEUE_PROFILE=durable-worker-job
OMNIWA_WORKER_PROVIDER_MODE=provider-runtime-bridge
OMNIWA_PROVIDER_COMMAND_BRIDGE_URL=http://provider-runtime:3011/internal/provider-command/v1/commands
OMNIWA_PROVIDER_COMMAND_BRIDGE_TOKEN=replace-with-provider-command-bridge-token

OMNIWA_PROVIDER_RUNTIME_PROFILE=local
OMNIWA_PROVIDER_RUNTIME_OWNERSHIP_MODE=postgresql
OMNIWA_PROVIDER_RUNTIME_OWNERSHIP_DATABASE_URL=postgresql://omniwa_app_prod:replace-with-postgres-secret@postgres:5432/omniwa
OMNIWA_BAILEYS_AUTH_STATE_ENCRYPTION_KEY=replace-with-32-byte-or-longer-auth-state-key
OMNIWA_LIVE_DEMO_MODE=disabled

OMNIWA_BACKGROUND_RUNTIME_PROFILE=production
OMNIWA_BACKGROUND_EVENT_LOG_BACKEND=postgresql
OMNIWA_EVENT_OUTBOX_LOOP_INTERVAL_MS=5000

OMNIWA_WEBHOOK_DISPATCHER_RUNTIME_PROFILE=production
OMNIWA_WEBHOOK_DISPATCHER_REPOSITORY_PROFILE=postgresql
OMNIWA_WEBHOOK_DISPATCHER_QUEUE_PROFILE=durable-worker-job
OMNIWA_WEBHOOK_DISPATCHER_HTTP_GATEWAY=fetch
OMNIWA_WEBHOOK_SIGNING_SECRET=replace-with-webhook-signing-secret
