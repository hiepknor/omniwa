# Local Docker defaults for OmniWA.
# Use only for local development or a private disposable staging host.

OMNIWA_API_PUBLIC_PORT=3000
OMNIWA_API_KEY=local-dev-secret-change-me
OMNIWA_API_KEY_ID=local-dev-key
OMNIWA_API_KEY_KIND=admin_key
OMNIWA_API_KEY_SCOPES=instances:read,instances:write,instances:connect,instances:destroy,messages:send,messages:read,messages:retry,messages:cancel,media:write,media:read,chats:read,contacts:read,labels:read,groups:read,groups:write,groups:message,groups:admin,webhooks:write,webhooks:read,webhooks:retry,webhooks:redrive,health:read,events:read
OMNIWA_API_REPOSITORY_PROFILE=postgresql
OMNIWA_WORKER_REPOSITORY_PROFILE=postgresql
OMNIWA_WORKER_LOOP_INTERVAL_MS=5000
OMNIWA_WEBHOOK_DISPATCHER_REPOSITORY_PROFILE=durable-json
OMNIWA_WEBHOOK_DISPATCHER_LOOP_INTERVAL_MS=5000
OMNIWA_WEBHOOK_DISPATCHER_RETRY_DELAY_MS=1000
OMNIWA_POSTGRES_AUTO_MIGRATE=true
OMNIWA_POSTGRES_PASSWORD=omniwa-local-password
OMNIWA_POSTGRES_PUBLIC_PORT=55432
OMNIWA_POSTGRES_TEST_DATABASE_URL=postgresql://omniwa:omniwa-local-password@127.0.0.1:55432/omniwa
